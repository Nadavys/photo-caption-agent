# Ollama API endpoint — use https://api.ollama.com for the cloud API,
# or http://localhost:11434 for a local Ollama instance.
OLLAMA_HOST=https://api.ollama.com

# Required for api.ollama.com; leave blank for local instances.
OLLAMA_API_KEY=your_api_key_here

# Main LLM — any Ollama model. Tested with gemma3:27b and ministral-3b:8b.
OLLAMA_MODEL=gemma3:27b

# Sampling temperature (optional, default 1.0).
OLLAMA_TEMPERATURE=1.0

# Vision model for image-to-description (optional, defaults to OLLAMA_MODEL).
# Must be a multimodal model (e.g. gemma3:27b, llava, moondream).
OLLAMA_VISION_MODEL=gemma3:27b
